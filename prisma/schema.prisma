// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ListingStatus {
  ACTIVE
  SOLD
  REMOVED
}

enum DeliveryJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  DEAD_LETTER
}

enum AdminActionType {
  TAKE_DOWN_LISTING
  RESTORE_LISTING
  RETRY_JOB
}

model User {
  id                String   @id @default(cuid())
  email             String?  @unique
  name              String?
  image             String?
  role              UserRole @default(USER)
  mastodonDomain    String
  mastodonAccountId String
  mastodonUsername  String
  mastodonActorUri  String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  listings Listing[]
  sessions Session[]

  @@unique([mastodonDomain, mastodonAccountId])
}

model MastodonOAuthClient {
  id           String   @id @default(cuid())
  domain       String   @unique
  clientId     String
  clientSecret String
  scopes       String
  redirectUri  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MastodonOAuthState {
  id             String   @id @default(cuid())
  state          String   @unique
  codeVerifier   String
  instanceDomain String
  redirectUri    String
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Listing {
  id                     String       @id @default(cuid())
  ownerId                String
  title                  String
  description            String
  priceAmount            Decimal?     @db.Decimal(10, 2)
  priceCurrency          String?
  location               String?
  category               String?
  status                 ListingStatus @default(ACTIVE)
  canonicalUrl           String        @unique
  activityPubObjectId    String        @unique
  latestOutboxActivityId String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  owner            User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images           ListingImage[]
  outboxActivities OutboxActivity[]

  @@index([status, createdAt(sort: Desc), id])
  @@index([ownerId, createdAt(sort: Desc)])
}

model ListingImage {
  id          String   @id @default(cuid())
  listingId   String
  key         String   @unique
  url         String
  contentType String
  sizeBytes   Int
  position    Int
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, position])
  @@index([listingId])
}

model FederationFollower {
  id          String   @id @default(cuid())
  actor       String   @unique
  inbox       String
  sharedInbox String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutboxActivity {
  id          String   @id @default(cuid())
  activityId  String   @unique
  activityType String
  listingId   String
  activityJson Json
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([publishedAt(sort: Desc)])
}

model FederationDeliveryJob {
  id            String            @id @default(cuid())
  targetActor   String?
  targetInbox   String
  activityId    String
  activityJson  Json
  status        DeliveryJobStatus @default(PENDING)
  attemptCount  Int               @default(0)
  maxAttempts   Int               @default(5)
  nextAttemptAt DateTime          @default(now())
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, nextAttemptAt])
  @@index([activityId])
}

model InboxActivityLog {
  id                String   @id @default(cuid())
  activityId        String   @unique
  actor             String
  activityType      String
  rawActivity       Json
  signatureValid    Boolean
  processed         Boolean  @default(false)
  processingError   String?
  receivedAt        DateTime @default(now())

  @@index([receivedAt(sort: Desc)])
  @@index([actor])
}

model AdminAction {
  id            String          @id @default(cuid())
  adminUserId   String
  actionType    AdminActionType
  targetId      String
  targetType    String
  details       Json?
  createdAt     DateTime @default(now())
}
