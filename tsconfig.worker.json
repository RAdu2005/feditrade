{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["esnext"],
    "types": ["node"],
    "allowJs": false,
    "incremental": false
  },
  "include": [
    "src/worker/**/*.ts",
    "src/lib/activitypub.ts",
    "src/lib/delivery-queue.ts",
    "src/lib/env.ts",
    "src/lib/logger.ts",
    "src/lib/prisma.ts"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "tests"
  ]
}
